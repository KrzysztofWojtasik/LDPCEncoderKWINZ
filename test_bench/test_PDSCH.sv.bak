// tb/tb_LDPC_encode.sv  (przerobiony pod PDSCHTx, ale debugger i wyjście nietknięte)
`timescale 1ns/1ps

module tb_PDSCH;

  localparam string VEC_DIR_IN     = "D:/Docs/Uczelnia/Dyplom1/vectors/Output_Matlab/PDSCH";
  localparam string VEC_DIR_GOLD   = "D:/Docs/Uczelnia/Dyplom1/vectors/Output_Matlab/PDSCH";
  localparam string VEC_DIR_META   = "D:/Docs/Uczelnia/Dyplom1/vectors/Output_Matlab/PDSCH";
  localparam string VEC_DIR_RESULT = "D:/Docs/Uczelnia/Dyplom1/vectors/Output_DUT/PDSCH_output";

  localparam string CASE = "A57";

  localparam int W = 64;
  localparam int TIMEOUT_CYCLES = 2_000_000;
  localparam int MAX_ERR_PRINT_DEFAULT = 1000;

  logic        clk;
  logic        rst;

  // ====== WEJŚCIE pod PDSCHTx ======
  logic [63:0] in_chunk;
  logic        in_valid;
  logic        in_last;
  logic [15:0] tb_len;


  logic        out_valid;
  logic [63:0] out_chunk;
  logic        out_last;
  logic [5:0]  out_pad_left;
  logic [5:0]  out_pad_right;


  // ====== DUT: PDSCHTx ======
  PDSCHTx dut (
    .clk(clk),
    .rst(rst),
    .in_chunk(in_chunk),
    .in_valid(in_valid),
    .in_last(in_last),
    .tb_len(tb_len),
    .out_chunk(out_chunk),
    .out_valid(out_valid),
    .out_last(out_last),
    .out_pad_left(out_pad_left),
    .out_pad_right(out_pad_right)
  );

  string in_file;
  string golden_file;
  string meta_file;
  string out_dump_file;
  int    fd_dump;

  // UWAGA: zostawiam Twoje struktury, ale input będzie w tb_cb[0] jako cały TB
  bit tb_cb[int][$];
  bit golden_cb[int][$];

  // META: zostawiam stare pola (nie przeszkadzają), dodaję A
  int META_CB_COUNT = 0;
  int META_K        = -1;
  int META_F        = -1;
  int META_ZC       = -1;
  int META_BG       = -1;
  int META_A        = -1;

  initial begin
    clk = 0;
    forever #5 clk = ~clk;
  end

  initial begin
    if ($test$plusargs("DUMP")) begin
      $dumpfile("tb_PDSCH.vcd");
      $dumpvars(0, tb_PDSCH);
    end
  end

  integer cyc;
  integer prev_out_valid_crc;
  integer prev_out_last_crc;
  integer prev_out_valid_prep;
  integer prev_out_last_chunk_prep;
  integer prev_out_last_cb_prep;
  

