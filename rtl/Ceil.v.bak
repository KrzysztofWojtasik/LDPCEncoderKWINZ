//Ceil module, 16 bit input, 9bit output, synchronous

module Ceil (
  input  wire [15:0]  num,   // numerator
  input  wire [15:0]  den,   // denominator
  input  wire         rst,   
  input  wire         enable,
  input  wire    	 	 clk,    
  output reg  [15:0]  ceil,   // result(ceil)
  output reg  		 	 result_valid,
  output reg  [15:0]  reminder
);

	localparam [1:0] S_IDLE   = 2'd0;
	localparam [1:0] S_CALC   = 2'd1;
	localparam [1:0] S_RESULT = 2'd2;
	

	reg   [15:0]   num_r;
	reg   [15:0]   den_r;
	reg  	[15:0]	result;
	reg	[1:0]		state;
	
	always @(posedge clk) begin
    if (~rst) begin
      state     	 <= S_IDLE;
      ceil 		 	 <= 8'b0;
		result	 	 <= 16'b0;
		result_valid <= 1'b0;
		num_r		 	 <= 15'b0;
		den_r	 		 <= 15'b0;
	 end else begin
      // domyślnie brak wyjścia
      ceil  		 <= 1'b0;
		result_valid <= 1'b0;
    case (state)
        // ------------------------------ IDLE ---------------------------------
        S_IDLE: begin
				if (enable) begin
					num_r  <= num;
					den_r  <= den;
					result <= 1'b0;
					state  <= S_CALC;
				end
        end

        // ------------------------------ CALC ---------------------------------
        S_CALC: begin
          if (enable) begin
            num_r  <= num_r - den_r;
				result <= result + 1'b1;
				if (num_r <= den_r) begin
					state <= S_RESULT;
					reminder <= (num_r== den_r) ? 15'b0 : num_r;
				end
          end
        end

        // ------------------------------ RESULT ----------
        S_RESULT: begin
          if (enable) begin
				result_valid <= 1'b1;
				ceil 			 <= result;
			 end else begin
				state <= S_IDLE;
			 end
        end

        default: begin
          state <= S_IDLE;
        end
      endcase
    end
  end
endmodule
	
	